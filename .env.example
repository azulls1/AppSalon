# =========================
# Supabase (autohospedado)
# =========================
SUPABASE_URL=https://supabase.tu-dominio.com
SUPABASE_ANON_KEY=eyJhbGciOi...      # anon public key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi... # service role (SOLO backend, nunca frontend)
SUPABASE_JWT_SECRET=tu-jwt-secret      # para verificar tokens

# =========================
# Redis (broker Celery)
# =========================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# =========================
# SMTP (envío de emails desde worker)
# =========================
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=cuentas@appsalon.com
SMTP_FROM_NAME=AppSalon

# =========================
# App
# =========================
APP_ENV=development
APP_BASE_URL=http://localhost:4200
API_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:4200
